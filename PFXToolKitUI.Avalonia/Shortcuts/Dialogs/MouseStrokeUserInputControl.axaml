<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PFXToolKitUI.Avalonia.Shortcuts.Dialogs.MouseStrokeUserInputControl">
    <Grid>
        <TextBlock Margin="10,10,10,0" VerticalAlignment="Top" Padding="2" Text="Click any mouse button in here:"/>
        <Border x:Name="PART_Border" 
                Margin="10,35,10,10" 
                Background="{DynamicResource ABrush.Tone1.Background.Static}" 
                BorderBrush="{DynamicResource ABrush.Tone3.Border.Static}" 
                BorderThickness="1">
            <TextBlock x:Name="InputBox" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>